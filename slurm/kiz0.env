# SLURM parameters for the kiz0 cluster. Single source of truth for the
# sbatch header; edit here, not in the template. Empty values are dropped from
# the generated #SBATCH header.

PARTITION="p1,p2,p6"
GRES="gpu:1"
QOS="gpuultimate"
ACCOUNT=""
TIME_LIMIT="04:00:00"

# Python environment on the node (venv was chosen for kiz0).
VENV_PATH=".venv"
# Optional module loads, e.g. MODULE_LOAD="module load cuda/12.1"
MODULE_LOAD=""

# Where job stdout/stderr go (relative to the project dir).
LOG_DIR="slurm/logs"
